{
  "terraform": {
    "required_providers": {
      "huaweicloud": {
        "source": "huawei.com/provider/huaweicloud",
        "version": ">=1.70.1"
      }
    }
  },
  "provider": {
    "huaweicloud": {
      "cloud": "myhuaweicloud.com",
      "region": "cn-north-4",
      "insecure": true,
      "auth_url": "https://iam.cn-north-4.myhuaweicloud.com/v3"
    }
  },
  "variable": {
    "vpc_name": {
      "default": "openhands-demo",
      "description": "虚拟私有云名称前缀，自动追加随机后缀。",
      "type": "string"
    },
    "ecs_name": {
      "default": "openhands-demo",
      "description": "云服务器名称前缀，自动追加随机后缀。",
      "type": "string"
    },
    "ecs_flavor": {
      "default": "x1.2u.4g",
      "description": "Flexus X 实例规格。OpenHands 推荐 2vCPUs 4GiB 及以上。",
      "type": "string"
    },
    "ecs_password": {
      "default": "",
      "description": "云服务器密码，8-26位。",
      "type": "string",
      "sensitive": true
    },
    "system_disk_size": {
      "default": 60,
      "description": "系统盘(GB)，高IO，40-1024。",
      "type": "number"
    },
    "bandwidth_size": {
      "default": 10,
      "description": "弹性公网带宽(Mbit/s)，按流量计费。",
      "type": "number"
    },
    "charging_mode": {
      "default": "postPaid",
      "description": "计费模式。",
      "type": "string"
    },
    "charging_unit": {
      "default": "month",
      "type": "string"
    },
    "charging_period": {
      "default": 1,
      "type": "number"
    }
  },
  "locals": {
    "name_suffix": "${substr(uuid(), 0, 8)}"
  },
  "data": {
    "huaweicloud_images_image": {
      "Ubuntu": {
        "most_recent": true,
        "name": "Ubuntu 22.04 server 64bit",
        "visibility": "public"
      }
    }
  },
  "resource": {
    "huaweicloud_vpc": {
      "vpc": {
        "name": "${var.vpc_name}-${local.name_suffix}",
        "cidr": "172.16.0.0/16"
      }
    },
    "huaweicloud_vpc_subnet": {
      "subnet": {
        "name": "${var.vpc_name}-${local.name_suffix}-subnet",
        "cidr": "172.16.1.0/24",
        "gateway_ip": "172.16.1.1",
        "vpc_id": "${huaweicloud_vpc.vpc.id}"
      }
    },
    "huaweicloud_networking_secgroup": {
      "secgroup": {
        "name": "${var.ecs_name}-${local.name_suffix}"
      }
    },
    "huaweicloud_networking_secgroup_rule": {
      "openhands_web": {
        "security_group_id": "${huaweicloud_networking_secgroup.secgroup.id}",
        "description": "OpenHands Web UI",
        "direction": "ingress",
        "ethertype": "IPv4",
        "protocol": "tcp",
        "ports": 3000,
        "remote_ip_prefix": "0.0.0.0/0"
      },
      "cloud_shell": {
        "security_group_id": "${huaweicloud_networking_secgroup.secgroup.id}",
        "description": "Cloud Shell SSH",
        "direction": "ingress",
        "ethertype": "IPv4",
        "protocol": "tcp",
        "ports": 22,
        "remote_ip_prefix": "121.36.59.153/32"
      }
    },
    "huaweicloud_vpc_eip": {
      "vpc_eip": {
        "name": "${var.vpc_name}-${local.name_suffix}-eip",
        "bandwidth": {
          "name": "${var.vpc_name}-${local.name_suffix}-bw",
          "share_type": "PER",
          "size": "${var.bandwidth_size}",
          "charge_mode": "traffic"
        },
        "publicip": { "type": "5_bgp" },
        "charging_mode": "postPaid"
      }
    },
    "huaweicloud_compute_instance": {
      "compute_instance": {
        "name": "${var.ecs_name}-${local.name_suffix}",
        "image_id": "${data.huaweicloud_images_image.Ubuntu.id}",
        "flavor_id": "${var.ecs_flavor}",
        "security_group_ids": ["${huaweicloud_networking_secgroup.secgroup.id}"],
        "system_disk_type": "SAS",
        "system_disk_size": "${var.system_disk_size}",
        "admin_pass": "${var.ecs_password}",
        "delete_disks_on_termination": true,
        "network": { "uuid": "${huaweicloud_vpc_subnet.subnet.id}" },
        "agent_list": "hss,ces",
        "eip_id": "${huaweicloud_vpc_eip.vpc_eip.id}",
        "charging_mode": "${var.charging_mode}",
        "period_unit": "${var.charging_unit}",
        "period": "${var.charging_period}",
        "tags": { "app": "openhands" },
        "user_data": "#!/bin/bash\necho 'root:${var.ecs_password}' | chpasswd\nLOG=\"/var/log/openhands-bootstrap.log\"\nexec > >(tee -a \"$LOG\") 2>&1\necho \"[$(date)] Bootstrap: start\"\ncurl -fsSL -o /tmp/install_openhands.sh \"https://tp-00940108.obs.cn-south-1.myhuaweicloud.com/install_openhands.sh\"\nchmod +x /tmp/install_openhands.sh\nbash /tmp/install_openhands.sh\nRC=$?\necho \"[$(date)] Bootstrap: finished (exit=$RC)\"\nexit $RC"
      }
    }
  },
  "output": {
    "说明": {
      "depends_on": ["huaweicloud_vpc_eip.vpc_eip"],
      "value": "部署完成后（约10分钟），在浏览器访问 http://${huaweicloud_vpc_eip.vpc_eip.address}:3000/ 进入 OpenHands Web UI。首次使用需配置 LLM API Key。SSH：ssh root@${huaweicloud_vpc_eip.vpc_eip.address}，日志：/var/log/openhands-install.log"
    }
  }
}

{
  "variables": {
    "grouping": {
      "network_config": {
        "label": "网络配置",
        "description": "配置虚拟私有云VPC及弹性公网IP带宽参数"
      },
      "ecs_config": {
        "label": "ECS 配置",
        "description": "配置云服务器规格、登录密码及系统盘大小"
      },
      "charging_config": {
        "label": "计费配置",
        "description": "配置计费模式（按需/包年包月）及购买时长"
      }
    }
  },
  "i18n": {
    "zh-cn": {
      "variable": {
        "vpc_name": { "description": "虚拟私有云名称，该模板新建VPC。取值范围：1-54个字符。默认：supabase-backend-platform-demo" },
        "security_group_name": { "description": "安全组名称，该模板新建安全组。取值范围：1-64个字符。默认：supabase-backend-platform-demo" },
        "ecs_name": { "description": "云服务器实例名称。取值范围：1-64个字符。默认：supabase-backend-platform-demo" },
        "ecs_flavor": { "description": "云服务器实例规格。Supabase需同时运行约10个Docker容器，推荐x1.8u.16g（8vCPUs 16GiB）及以上。默认：x1.8u.16g" },
        "ecs_password": { "description": "云服务器root密码，8-26位，包含大写字母、小写字母、数字和特殊字符中的三种" },
        "db_password": { "description": "Supabase PostgreSQL数据库密码，8-26位。同时作为authenticator、supabase_auth_admin、supabase_storage_admin角色密码。可与ECS密码相同或不同" },
        "system_disk_size": { "description": "系统盘大小（GB），高IO SAS类型。Docker镜像+PG数据约10GB，推荐100GB起步。取值范围40-1024" },
        "bandwidth_size": { "description": "弹性公网带宽大小（Mbit/s），按流量计费。取值范围1-300。默认：300" },
        "charging_mode": { "description": "计费模式：postPaid（按需）或 prePaid（包年包月）。默认：postPaid" },
        "charging_unit": { "description": "包年包月单位：month（月）或 year（年）。prePaid时必填。默认：month" },
        "charging_period": { "description": "包年包月购买时长。按月1-9，按年1-3。prePaid时必填。默认：1" }
      }
    },
    "en-us": {
      "variable": {
        "vpc_name": { "description": "VPC name, new VPC created by this template. 1-54 chars. Default: supabase-backend-platform-demo" },
        "security_group_name": { "description": "Security group name, new SG created. 1-64 chars. Default: supabase-backend-platform-demo" },
        "ecs_name": { "description": "ECS instance name. 1-64 chars. Default: supabase-backend-platform-demo" },
        "ecs_flavor": { "description": "ECS flavor. Supabase runs ~10 Docker containers, x1.8u.16g (8vCPUs 16GiB) recommended. Default: x1.8u.16g" },
        "ecs_password": { "description": "ECS root password, 8-26 chars, 3 of 4 types (uppercase, lowercase, digits, special chars)" },
        "db_password": { "description": "Supabase PostgreSQL password, 8-26 chars. Also used for authenticator, supabase_auth_admin, supabase_storage_admin roles. Can be same as or different from ECS password" },
        "system_disk_size": { "description": "System disk in GB (SAS high-IO). Docker images + PG data ~10GB, 100GB recommended. Range: 40-1024" },
        "bandwidth_size": { "description": "EIP bandwidth in Mbit/s, traffic billing. Range 1-300. Default: 300" },
        "charging_mode": { "description": "Billing: postPaid or prePaid. Default: postPaid" },
        "charging_unit": { "description": "PrePaid unit: month or year. Required for prePaid. Default: month" },
        "charging_period": { "description": "PrePaid period: 1-9 (month), 1-3 (year). Required for prePaid. Default: 1" }
      }
    }
  }
}

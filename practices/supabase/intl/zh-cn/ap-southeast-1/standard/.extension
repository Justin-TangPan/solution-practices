{
  "variables": {
    "grouping": {
      "network_config": {
        "label": "网络配置",
        "description": "配置VPC和弹性公网带宽参数"
      },
      "ecs_config": {
        "label": "弹性云服务器配置",
        "description": "配置服务器规格、密码和系统盘大小"
      },
      "supabase_config": {
        "label": "Supabase 配置",
        "description": "配置 Supabase 数据库密码"
      },
      "charging_config": {
        "label": "计费配置",
        "description": "配置计费模式（按需/包年包月）和购买周期"
      }
    }
  },
  "i18n": {
    "en-us": {
      "variable": {
        "solution_name": { "description": "Solution name, 4-24 chars, lowercase letters/digits/hyphens, must start with a lowercase letter. Default: supabase" },
        "ecs_flavor": { "description": "ECS flavor. Supabase runs ~10 Docker containers, c7n.2xlarge.2 (8vCPUs 16GiB) or above recommended. Change to match available flavors in target region. Default: c7n.2xlarge.2" },
        "ecs_password": { "description": "ECS root password, 8-26 chars, at least 3 of: uppercase, lowercase, digits, special characters" },
        "db_password": { "description": "PostgreSQL password, 8-26 chars. Used as the password for all database roles (authenticator, supabase_auth_admin, supabase_storage_admin)" },
        "system_disk_size": { "description": "System disk in GB (high-IO SAS). Docker images + DB data. 100GB recommended. Range: 40-1024" },
        "bandwidth_size": { "description": "EIP bandwidth in Mbit/s, traffic billing. Range 1-300. Default: 300" },
        "charging_mode": { "description": "Billing: postPaid (pay-per-use) or prePaid (subscription). Default: postPaid" },
        "charging_unit": { "description": "Subscription unit: month or year. Required for prePaid. Default: month" },
        "charging_period": { "description": "Subscription period: 1-9 (month), 1-3 (year). Required for prePaid. Default: 1" }
      }
    },
    "zh-cn": {
      "variable": {
        "solution_name": { "description": "解决方案名称，4-24字符，小写字母/数字/中划线，小写字母开头。默认：supabase" },
        "ecs_flavor": { "description": "云服务器实例规格。Supabase需同时运行约10个Docker容器，推荐c7n.2xlarge.2（8vCPUs 16GiB）及以上。请根据目标区域可用规格调整。默认：c7n.2xlarge.2" },
        "ecs_password": { "description": "云服务器root密码，8-26位，包含大写字母、小写字母、数字和特殊字符中的三种" },
        "db_password": { "description": "PostgreSQL数据库密码，8-26位。将同时作为所有数据库角色（authenticator、supabase_auth_admin、supabase_storage_admin）的密码" },
        "system_disk_size": { "description": "系统盘大小（GB），高IO SAS类型。Docker镜像+数据库数据，推荐100GB起步。取值范围40-1024" },
        "bandwidth_size": { "description": "弹性公网带宽大小（Mbit/s），按流量计费。取值范围1-300。默认：300" },
        "charging_mode": { "description": "计费模式：postPaid（按需）或 prePaid（包年包月）。默认：postPaid" },
        "charging_unit": { "description": "包年包月单位：month（月）或 year（年）。prePaid时必填。默认：month" },
        "charging_period": { "description": "包年包月购买时长。按月1-9，按年1-3。prePaid时必填。默认：1" }
      }
    }
  }
}

{
  "variables": {
    "grouping": {
      "network_config": {
        "label": "Network Configuration",
        "description": "Configure VPC and EIP bandwidth parameters"
      },
      "ecs_config": {
        "label": "ECS Configuration",
        "description": "Configure server flavor, password and system disk size"
      },
      "supabase_config": {
        "label": "Supabase Configuration",
        "description": "Configure Supabase database password"
      },
      "charging_config": {
        "label": "Billing Configuration",
        "description": "Configure billing mode (pay-per-use/subscription) and purchase period"
      }
    }
  },
  "i18n": {
    "en-us": {
      "variable": {
        "solution_name": { "description": "Solution name, 4-24 chars, lowercase letters/digits/hyphens; start with a lowercase letter and end with a lowercase letter or digit. Default: supabase" },
        "ecs_flavor": { "description": "ECS flavor. The official default Supabase stack runs 11 Docker services; c7n.2xlarge.2 (8vCPUs 16GiB) or above recommended. Change to match available flavors in target region. Default: c7n.2xlarge.2" },
        "ecs_password": { "description": "ECS root password, 8-26 chars, at least 3 of: uppercase, lowercase, digits, special characters" },
        "db_password": { "description": "PostgreSQL password. No template-side character whitelist; special characters are supported. Use a strong password" },
        "system_disk_size": { "description": "System disk in GB (high-IO SAS). Docker images + DB data. 100GB recommended. Range: 40-1024" },
        "bandwidth_size": { "description": "EIP bandwidth in Mbit/s, traffic billing. Range 1-300. Default: 300" },
        "charging_mode": { "description": "Billing: postPaid (pay-per-use) or prePaid (subscription). Default: postPaid" },
        "charging_unit": { "description": "Subscription unit: month or year. Required for prePaid. Default: month" },
        "charging_period": { "description": "Subscription period: 1-9 (month), 1-3 (year). Required for prePaid. Default: 1" }
      }
    },
    "zh-cn": {
      "variable": {
        "solution_name": { "description": "解决方案名称，4-24字符，仅含小写字母/数字/中划线；以小写字母开头，以小写字母或数字结尾。默认：supabase" },
        "ecs_flavor": { "description": "云服务器实例规格。Supabase官方默认栈包含11个Docker服务，推荐c7n.2xlarge.2（8vCPUs 16GiB）及以上。请根据目标区域可用规格调整。默认：c7n.2xlarge.2" },
        "ecs_password": { "description": "云服务器root密码，8-26位，包含大写字母、小写字母、数字和特殊字符中的三种" },
        "db_password": { "description": "PostgreSQL数据库密码，模板不限制字符类型，支持特殊字符，请使用高强度密码" },
        "system_disk_size": { "description": "系统盘大小（GB），高IO SAS类型。Docker镜像+数据库数据，推荐100GB起步。取值范围40-1024" },
        "bandwidth_size": { "description": "弹性公网带宽大小（Mbit/s），按流量计费。取值范围1-300。默认：300" },
        "charging_mode": { "description": "计费模式：postPaid（按需）或 prePaid（包年包月）。默认：postPaid" },
        "charging_unit": { "description": "包年包月单位：month（月）或 year（年）。prePaid时必填。默认：month" },
        "charging_period": { "description": "包年包月购买时长。按月1-9，按年1-3。prePaid时必填。默认：1" }
      }
    }
  }
}

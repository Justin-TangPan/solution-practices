{
  "variables": {
    "grouping": {
      "network_config": {
        "label": "网络配置",
        "description": "配置虚拟私有云VPC及弹性公网IP带宽参数"
      },
      "ecs_config": {
        "label": "ECS 配置",
        "description": "配置云服务器规格、登录密码及系统盘大小"
      },
      "charging_config": {
        "label": "计费配置",
        "description": "配置计费模式（按需/包年包月）及购买时长"
      }
    }
  },
  "i18n": {
    "zh-cn": {
      "variable": {
        "codewhale_version": { "description": "CodeWhale版本号，支持latest及v0.8.47。CodeWhale是基于DeepSeek V4的终端AI编程智能体。默认：latest" },
        "vpc_name": { "description": "虚拟私有云名称，该模板新建VPC。取值范围：1-54个字符。默认：codewhale-AI-coding-assistant-demo" },
        "security_group_name": { "description": "安全组名称，该模板新建安全组。取值范围：1-64个字符。默认：codewhale-AI-coding-assistant-demo" },
        "ecs_name": { "description": "云服务器实例名称。取值范围：1-64个字符。默认：codewhale-AI-coding-assistant-demo" },
        "ecs_flavor": { "description": "云服务器实例规格。Flexus X实例规格ID格式为x1.?u.?g。推荐x1.2u.4g（2vCPUs 4GiB）。默认：x1.2u.4g" },
        "ecs_password": { "description": "云服务器root密码，8-26位，包含大写字母、小写字母、数字和特殊字符中的三种" },
        "system_disk_size": { "description": "系统盘大小（GB），高IO SAS类型。CodeWhale为单二进制工具，默认60GB即可。取值范围40-1024" },
        "bandwidth_size": { "description": "弹性公网带宽大小（Mbit/s），按流量计费。取值范围1-300。默认：300" },
        "charging_mode": { "description": "计费模式：postPaid（按需）或 prePaid（包年包月）。默认：postPaid" },
        "charging_unit": { "description": "包年包月单位：month（月）或 year（年）。prePaid时必填。默认：month" },
        "charging_period": { "description": "包年包月购买时长。按月1-9，按年1-3。prePaid时必填。默认：1" }
      }
    },
    "en-us": {
      "variable": {
        "codewhale_version": { "description": "CodeWhale version, supports latest and v0.8.47. CodeWhale is a DeepSeek V4 terminal AI coding agent. Default: latest" },
        "vpc_name": { "description": "VPC name, new VPC created by this template. 1-54 chars. Default: codewhale-AI-coding-assistant-demo" },
        "security_group_name": { "description": "Security group name, new SG created by this template. 1-64 chars. Default: codewhale-AI-coding-assistant-demo" },
        "ecs_name": { "description": "ECS instance name. 1-64 chars. Default: codewhale-AI-coding-assistant-demo" },
        "ecs_flavor": { "description": "ECS flavor. Flexus X format: x1.?u.?g. x1.2u.4g (2vCPUs 4GiB) recommended. Default: x1.2u.4g" },
        "ecs_password": { "description": "ECS root password, 8-26 chars, 3 of 4 types (uppercase, lowercase, digits, special chars)" },
        "system_disk_size": { "description": "System disk in GB (SAS high-IO). CodeWhale is single-binary, 60GB default sufficient. Range: 40-1024" },
        "bandwidth_size": { "description": "EIP bandwidth in Mbit/s, traffic billing. Range 1-300. Default: 300" },
        "charging_mode": { "description": "Billing: postPaid or prePaid. Default: postPaid" },
        "charging_unit": { "description": "PrePaid unit: month or year. Required for prePaid. Default: month" },
        "charging_period": { "description": "PrePaid period: 1-9 (month), 1-3 (year). Required for prePaid. Default: 1" }
      }
    }
  }
}

{
  "variables": {
    "grouping": {
      "network_config": {
        "label": "网络配置",
        "description": "配置 VPC、安全组、EIP 与公网带宽"
      },
      "ecs_config": {
        "label": "云服务器配置",
        "description": "配置 ECS 规格、密码与系统盘容量"
      },
      "openjiuwen_config": {
        "label": "openJiuwen 配置",
        "description": "配置部署包地址、访问端口和 Embedding 模型参数"
      },
      "charging_config": {
        "label": "计费配置",
        "description": "配置按需或包年包月计费方式"
      }
    }
  },
  "i18n": {
    "zh-cn": {
      "variable": {
        "solution_name": { "description": "解决方案名称，4-24字符，小写字母/数字/中划线，小写字母开头。默认：openjiuwen" },
        "ecs_flavor": { "description": "云服务器实例规格。openJiuwen 会运行多个容器，推荐 x1.8u.16g（8vCPUs 16GiB）及以上。默认：x1.8u.16g" },
        "ecs_password": { "description": "云服务器 root 密码，8-26位，至少包含大写字母、小写字母、数字和特殊字符中的三种" },
        "system_disk_size": { "description": "系统盘大小（GB），高IO SAS类型。建议 200GB 起步，取值范围100-1024。默认：200" },
        "bandwidth_size": { "description": "弹性公网带宽（Mbit/s），按流量计费。首次部署需下载多个镜像，建议 100Mbit/s。默认：100" },
        "deploy_package_url": { "description": "openJiuwen Agent Studio 官方 Docker 部署工具包下载地址。默认使用 0.1.5 amd64 版本包" },
        "frontend_port": { "description": "openJiuwen Studio 前端公网访问端口。默认：3000" },
        "backend_port": { "description": "openJiuwen 后端 API 主机端口，仅用于运维和健康检查。默认：8000" },
        "runtime_port": { "description": "openJiuwen Agent Runtime 主机端口，用于 Agent 发布和运行态管理。默认：8186" },
        "embedding_api_base": { "description": "Embedding 模型 API Base，用于启用记忆/知识相关能力。留空时可部署后配置" },
        "embedding_model_name": { "description": "Embedding 模型名称。留空时可部署后配置" },
        "embedding_api_key": { "description": "Embedding 模型 API Key。留空时可部署后配置" },
        "charging_mode": { "description": "计费模式：postPaid（按需）或 prePaid（包年包月）。默认：postPaid" },
        "charging_unit": { "description": "包年包月单位：month（月）或 year（年）。prePaid 时生效。默认：month" },
        "charging_period": { "description": "包年包月购买时长。按月1-9，按年1-3。prePaid 时生效。默认：1" }
      }
    },
    "en-us": {
      "variable": {
        "solution_name": { "description": "Solution name, 4-24 chars, lowercase letters/digits/hyphens, must start with a lowercase letter. Default: openjiuwen" },
        "ecs_flavor": { "description": "ECS flavor. openJiuwen runs multiple containers; x1.8u.16g or above is recommended. Default: x1.8u.16g" },
        "ecs_password": { "description": "ECS root password, 8-26 chars, containing at least three of uppercase, lowercase, digits, and special characters" },
        "system_disk_size": { "description": "System disk size in GB. 200GB or above is recommended. Range: 100-1024. Default: 200" },
        "bandwidth_size": { "description": "EIP bandwidth in Mbit/s, traffic billing. Initial deployment downloads multiple images. Default: 100" },
        "deploy_package_url": { "description": "Official openJiuwen Agent Studio Docker deployment package URL. Default: 0.1.5 amd64 package" },
        "frontend_port": { "description": "Public port for openJiuwen Studio frontend. Default: 3000" },
        "backend_port": { "description": "Host port for openJiuwen backend API operations and health checks. Default: 8000" },
        "runtime_port": { "description": "Host port for openJiuwen Agent Runtime management. Default: 8186" },
        "embedding_api_base": { "description": "Embedding API base URL for memory and knowledge capabilities. Leave empty and configure after deployment if needed" },
        "embedding_model_name": { "description": "Embedding model name. Leave empty and configure after deployment if needed" },
        "embedding_api_key": { "description": "Embedding model API key. Leave empty and configure after deployment if needed" },
        "charging_mode": { "description": "Billing: postPaid or prePaid. Default: postPaid" },
        "charging_unit": { "description": "Subscription unit: month or year. Effective only when prePaid is selected" },
        "charging_period": { "description": "Subscription period. 1-9 for months or 1-3 for years. Effective only when prePaid is selected" }
      }
    }
  }
}

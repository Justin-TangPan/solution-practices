{
  "variables": {
    "grouping": {
      "network_config": {
        "label": "网络配置",
        "description": "配置VPC和EIP带宽"
      },
      "ecs_config": {
        "label": "云服务器配置",
        "description": "配置ECS规格、密码和系统盘"
      },
      "charging_config": {
        "label": "计费配置",
        "description": "配置按需或包年包月计费方式"
      }
    }
  },
  "i18n": {
    "zh-cn": {
      "variable": {
        "solution_name": { "description": "解决方案名称，4-24字符，仅含小写字母、数字和中划线。默认：jiuwenswarm" },
        "ecs_flavor": { "description": "云服务器实例规格，推荐x1.4u.8g（4vCPUs、8GiB）或更高配置。默认：x1.4u.8g" },
        "ecs_password": { "description": "云服务器root密码，8-26位，至少包含大写字母、小写字母、数字和特殊字符中的三种" },
        "system_disk_size": { "description": "系统盘大小（GB），高IO SAS类型，取值范围40-1024。默认：80" },
        "bandwidth_size": { "description": "弹性公网带宽（Mbit/s），按流量计费，取值范围1-300。默认：300" },
        "charging_mode": { "description": "计费模式：postPaid（按需）或prePaid（包年包月）。默认：postPaid" },
        "charging_unit": { "description": "包年包月单位：month（月）或year（年）。默认：month" },
        "charging_period": { "description": "包年包月购买时长，按月1-9或按年1-3。默认：1" }
      }
    },
    "en-us": {
      "variable": {
        "solution_name": { "description": "Solution name, 4-24 lowercase letters, digits, or hyphens. Default: jiuwenswarm" },
        "ecs_flavor": { "description": "ECS flavor; x1.4u.8g (4 vCPUs, 8 GiB) or above recommended. Default: x1.4u.8g" },
        "ecs_password": { "description": "ECS root password, 8-26 characters containing at least three character classes" },
        "system_disk_size": { "description": "High-I/O SAS system disk in GB, range 40-1024. Default: 80" },
        "bandwidth_size": { "description": "EIP bandwidth in Mbit/s, traffic billing, range 1-300. Default: 300" },
        "charging_mode": { "description": "Billing mode: postPaid or prePaid. Default: postPaid" },
        "charging_unit": { "description": "Subscription unit: month or year. Default: month" },
        "charging_period": { "description": "Subscription period: 1-9 months or 1-3 years. Default: 1" }
      }
    }
  }
}

{
  "variables": {
    "grouping": {
      "network_config": {
        "label": "Network Configuration",
        "description": "Configure VPC and EIP bandwidth parameters"
      },
      "ecs_config": {
        "label": "ECS Configuration",
        "description": "Configure server flavor, password and system disk size"
      },
      "litellm_config": {
        "label": "LiteLLM Configuration",
        "description": "Configure LiteLLM master key and database password"
      },
      "charging_config": {
        "label": "Billing Configuration",
        "description": "Configure billing mode (pay-per-use/subscription) and purchase period"
      }
    }
  },
  "i18n": {
    "en-us": {
      "variable": {
        "solution_name": { "description": "Solution name, 4-24 chars, lowercase letters/digits/hyphens, must start with a lowercase letter. Default: litellm-llm-gateway" },
        "ecs_flavor": { "description": "ECS flavor. LiteLLM is lightweight, x1.2u.4g (2vCPUs 4GiB) or above recommended. Default: x1.2u.4g" },
        "ecs_password": { "description": "ECS root password, 8-26 chars, at least 3 of: uppercase, lowercase, digits, special characters" },
        "db_password": { "description": "PostgreSQL password, 8-26 chars. Used by LiteLLM for internal database (virtual keys, spend tracking). Can be same as or different from ECS password" },
        "master_key": { "description": "LiteLLM master key, must start with 'sk-'. Used for Admin UI login and API authentication. Example: sk-example-change-me" },
        "salt_key": { "description": "LiteLLM salt key for encrypting stored API keys. CANNOT be changed once used. Leave empty to auto-generate. Recommended to leave empty" },
        "system_disk_size": { "description": "System disk in GB (SAS high-IO). Docker images + PG data ~2GB, 40GB recommended. Range: 40-1024" },
        "bandwidth_size": { "description": "EIP bandwidth in Mbit/s, traffic billing. Range 1-300. Default: 300" },
        "charging_mode": { "description": "Billing: postPaid (pay-per-use) or prePaid (subscription). Default: postPaid" },
        "charging_unit": { "description": "Subscription unit: month or year. Required for prePaid. Default: month" },
        "charging_period": { "description": "Subscription period: 1-9 (month), 1-3 (year). Required for prePaid. Default: 1" }
      }
    },
    "zh-cn": {
      "variable": {
        "solution_name": { "description": "解决方案名称，4-24字符，小写字母/数字/中划线，小写字母开头。默认：litellm-llm-gateway" },
        "ecs_flavor": { "description": "云服务器实例规格。LiteLLM为轻量级代理，推荐x1.2u.4g（2vCPUs 4GiB）及以上。默认：x1.2u.4g" },
        "ecs_password": { "description": "云服务器root密码，8-26位，包含大写字母、小写字母、数字和特殊字符中的三种" },
        "db_password": { "description": "PostgreSQL数据库密码，8-26位。用于LiteLLM内部数据库（虚拟密钥、用量统计）。可与ECS密码相同或不同" },
        "master_key": { "description": "LiteLLM管理密钥，须以sk-开头。用于Admin UI登录及API鉴权。示例：sk-example-change-me" },
        "salt_key": { "description": "LiteLLM加密密钥，用于加密存储的API Key。一旦使用不可更改，留空则自动生成。建议留空" },
        "system_disk_size": { "description": "系统盘大小（GB），高IO SAS类型。Docker镜像+PG数据约2GB，推荐40GB起步。取值范围40-1024" },
        "bandwidth_size": { "description": "弹性公网带宽大小（Mbit/s），按流量计费。取值范围1-300。默认：300" },
        "charging_mode": { "description": "计费模式：postPaid（按需）或 prePaid（包年包月）。默认：postPaid" },
        "charging_unit": { "description": "包年包月单位：month（月）或 year（年）。prePaid时必填。默认：month" },
        "charging_period": { "description": "包年包月购买时长。按月1-9，按年1-3。prePaid时必填。默认：1" }
      }
    }
  }
}

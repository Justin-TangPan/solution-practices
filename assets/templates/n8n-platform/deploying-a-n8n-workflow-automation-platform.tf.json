{
    "terraform": {
        "required_providers": {
            "huaweicloud": {
                "source": "huawei.com/provider/huaweicloud",
                "version": ">=1.70.1"
            }
        }
    },
    "provider": {
        "huaweicloud": {
            "cloud": "myhuaweicloud.com",
            "endpoints": {
                "iam": "iam.cn-north-4.myhuaweicloud.com",
                "dns": "dns.cn-north-4.myhuaweicloud.com"
            },
            "region": "cn-north-4",
            "auth_url": "https://iam.cn-north-4.myhuaweicloud.com/v3"
        }
    },
    "variable": {
        "n8n_version": {
            "default": "latest",
            "description": "n8n工作流自动化平台版本，支持latest、1.84.0、1.81.2、1.76.3及1.63.4。n8n是由183k+星标的开源AI工作流自动化平台，支持400+集成、可视化编排及原生AI Agent能力。",
            "type": "string",
            "nullable": false,
            "validation": {
                "condition": "${contains([\"latest\",\"1.84.0\",\"1.81.2\",\"1.76.3\",\"1.63.4\"], var.n8n_version)}",
                "error_message": "Invalid input, please re-enter."
            }
        },
        "vpc_name": {
            "default": "n8n-workflow-automation-platform-demo",
            "description": "虚拟私有云名称前缀，默认值后自动追加随机后缀。取值范围：1-54个字符，支持中文、英文字母、数字、_（下划线）、-（中划线）、.（点）。",
            "type": "string",
            "nullable": false
        },
        "security_group_name": {
            "default": "n8n-workflow-automation-platform-demo",
            "description": "安全组名称前缀，默认值后自动追加随机后缀。取值范围：1-64个字符，支持数字、字母、中文、_(下划线)、-（中划线）、.（点）。",
            "type": "string",
            "nullable": false
        },
        "ecs_name": {
            "default": "n8n-workflow-automation-platform-demo",
            "description": "云服务器实例名称前缀，默认值后自动追加随机后缀。取值范围：1-64个字符，支持中文、英文字母、数字、_（下划线）、-（中划线）、.（点）。",
            "type": "string",
            "nullable": false
        },
        "ecs_flavor": {
            "default": "x1.4u.8g",
            "description": "Flexus云服务器X实例规格，规格ID命名规则为x1.?u.?g，例如2vCPUs4GiB规格ID为x1.2u.4g。n8n推荐4vCPUs8GiB及以上。具体华为云Flexus云服务器X实例规格请参考控制台。",
            "type": "string",
            "nullable": false,
            "validation": {
                "condition": "${length(regexall(\"^x1.([1-9]|1[0-6])u.([1-9][0-9]{0,1}|1[0-2][0-8])g$\",var.ecs_flavor))>0}",
                "error_message": "Invalid input. Please re-enter."
            }
        },
        "ecs_password": {
            "default": "",
            "description": "云服务器密码，取值范围：8-26个字符，密码至少包含大写字母、小写字母、数字和特殊字符（!@%^_=+[{}]:,.?）中的三种。管理员账户默认root。",
            "type": "string",
            "nullable": false,
            "sensitive": true
        },
        "system_disk_size": {
            "default": 60,
            "description": "云服务器系统盘大小，磁盘类型默认为高IO，单位：GB，取值范围为40-1,024，不支持缩盘。",
            "type": "number",
            "nullable": false,
            "validation": {
                "condition": "${length(regexall(\"^([4-9][0-9]|[1-9][0-9]{2}|10[01][0-9]|102[0-4]|1024)$\",var.system_disk_size))>0}",
                "error_message": "Invalid input. Please re-enter."
            }
        },
        "bandwidth_size": {
            "default": 10,
            "description": "弹性公网带宽大小，该模板计费方式为按流量计费。单位：Mbit/s，取值范围：1-300Mbit/s。",
            "type": "number",
            "nullable": false,
            "validation": {
                "condition": "${length(regexall(\"^([1-9][0-9]{0,1}|[1-2][0-9]{2}|300)$\",var.bandwidth_size))>0}",
                "error_message": "Invalid input. Please re-enter."
            }
        },
        "charging_mode": {
            "default": "postPaid",
            "description": "云服务器计费模式，默认自动扣费，可选值为：postPaid（按需计费）、prePaid（包年包月）。",
            "type": "string",
            "nullable": false,
            "validation": {
                "condition": "${contains([\"postPaid\",\"prePaid\"], var.charging_mode)}",
                "error_message": "Invalid input, please re-enter."
            }
        },
        "charging_unit": {
            "default": "month",
            "description": "云服务器订购周期类型，仅当charging_mode为prePaid（包年/包月）生效，此时该参数为必填参数。取值范围：month（月），year（年）。",
            "type": "string",
            "nullable": false,
            "validation": {
                "condition": "${contains([\"month\",\"year\"], var.charging_unit)}",
                "error_message": "Invalid input, please re-enter."
            }
        },
        "charging_period": {
            "default": 1,
            "description": "云服务器订购周期，仅当charging_mode为prePaid（包年/包月）生效，此时该参数为必填参数。取值范围：charging_unit=month（周期类型为月）时，取值为1-9；charging_unit=year（周期类型为年）时，取值为1-3。",
            "type": "number",
            "nullable": false,
            "validation": {
                "condition": "${length(regexall(\"^[1-9]$\",var.charging_period))>0}",
                "error_message": "Invalid input, please re-enter."
            }
        },
        "obs_base_url": {
            "default": "https://tp-00940108.obs.cn-south-1.myhuaweicloud.com",
            "description": "OBS 脚本分发桶地址，用于下载部署脚本。",
            "type": "string",
            "nullable": false
        }
    },
    "data": {
        "huaweicloud_images_image": {
            "Ubuntu": {
                "most_recent": true,
                "name": "Ubuntu 22.04 server 64bit",
                "visibility": "public"
            }
        },
        "huaweicloud_availability_zones": {
            "availability_zones": {
            }
        }
    },
    "locals": {
        "multi_az": "${join(\",\", slice(data.huaweicloud_availability_zones.availability_zones.names, 0, 1))}"
    },
    "resource": {
        "huaweicloud_vpc": {
            "vpc": {
                "name": "${var.vpc_name}",
                "cidr": "172.16.0.0/16"
            }
        },
        "huaweicloud_vpc_subnet": {
            "subnet": {
                "name": "${var.vpc_name}-subnet",
                "cidr": "172.16.1.0/24",
                "gateway_ip": "172.16.1.1",
                "vpc_id": "${huaweicloud_vpc.vpc.id}"
            }
        },
        "huaweicloud_networking_secgroup": {
            "secgroup": {
                "name": "${var.security_group_name}"
            }
        },
        "huaweicloud_networking_secgroup_rule": {
            "n8n_HTTP": {
                "security_group_id": "${huaweicloud_networking_secgroup.secgroup.id}",
                "description": "n8n Web控制台默认端口，允许访问n8n工作流编排界面",
                "direction": "ingress",
                "ethertype": "IPv4",
                "protocol": "tcp",
                "ports": 5678,
                "remote_ip_prefix": "0.0.0.0/0"
            },
            "n8n_HTTPS": {
                "security_group_id": "${huaweicloud_networking_secgroup.secgroup.id}",
                "description": "HTTPS协议网络端口，允许安全访问n8n平台",
                "direction": "ingress",
                "ethertype": "IPv4",
                "protocol": "tcp",
                "ports": 443,
                "remote_ip_prefix": "0.0.0.0/0"
            },
            "cloud_shell": {
                "security_group_id": "${huaweicloud_networking_secgroup.secgroup.id}",
                "description": "Cloud Shell默认端口，通过Cloud Shell登录服务器",
                "direction": "ingress",
                "ethertype": "IPv4",
                "protocol": "tcp",
                "ports": 22,
                "remote_ip_prefix": "121.36.59.153/32"
            }
        },
        "huaweicloud_vpc_eip": {
            "vpc_eip": {
                "name": "${var.vpc_name}-n8n",
                "bandwidth": {
                    "name": "${var.vpc_name}-bandwidth",
                    "share_type": "PER",
                    "size": "${var.bandwidth_size}",
                    "charge_mode": "traffic"
                },
                "publicip": {
                    "type": "5_bgp"
                },
                "charging_mode": "postPaid"
            }
        },
        "huaweicloud_compute_instance": {
            "compute_instance_n8n": {
                "name": "${var.ecs_name}",
                "image_id": "${data.huaweicloud_images_image.Ubuntu.id}",
                "flavor_id": "${var.ecs_flavor}",
                "security_group_ids": [
                    "${huaweicloud_networking_secgroup.secgroup.id}"
                ],
                "system_disk_type": "SAS",
                "system_disk_size": "${var.system_disk_size}",
                "admin_pass": "${var.ecs_password}",
                "delete_disks_on_termination": true,
                "network": {
                    "uuid": "${huaweicloud_vpc_subnet.subnet.id}"
                },
                "agent_list": "hss,ces",
                "eip_id": "${huaweicloud_vpc_eip.vpc_eip.id}",
                "charging_mode": "${var.charging_mode}",
                "period_unit": "${var.charging_unit}",
                "period": "${var.charging_period}",
                "tags": {
                    "app": "n8n"
                },
                "user_data": "#!/bin/bash\necho 'root:${var.ecs_password}' | chpasswd\nBOOT_LOG=\"/var/log/n8n-bootstrap.log\"\nexec > >(tee -a \"$BOOT_LOG\") 2>&1\necho \"[$(date)] Bootstrap: start, N8N_VERSION=${var.n8n_version}\"\nSCRIPT=\"/tmp/install_n8n.sh\"\nOBS_URL=\"${var.obs_base_url}/install_n8n.sh\"\necho \"[$(date)] Bootstrap: downloading $OBS_URL ...\"\ncurl -fsSL -o \"$SCRIPT\" \"$OBS_URL\"\nchmod +x \"$SCRIPT\"\necho \"[$(date)] Bootstrap: script downloaded, executing...\"\nbash \"$SCRIPT\" \"${var.n8n_version}\"\nRC=$?\necho \"[$(date)] Bootstrap: finished (exit=$RC)\"\nexit $RC"
            }
        }
    },
    "output": {
        "说明": {
            "depends_on": [
                "huaweicloud_vpc_eip.vpc_eip"
            ],
            "value": "等待应用下载及部署完毕（约10分钟）后，请在浏览器上输入网址：http://${huaweicloud_vpc_eip.vpc_eip.address}:5678/，即可访问n8n工作流自动化平台。首次访问请在Web界面注册管理员账户。SSH登录命令：ssh root@${huaweicloud_vpc_eip.vpc_eip.address}，部署日志：/var/log/n8n-install.log"
        }
    }
}

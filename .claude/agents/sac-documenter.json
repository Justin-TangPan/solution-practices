{
  "name": "sac-documenter",
  "description": "SAC 文档 Agent — 方案文档编写与生成",
  "roles": [
    "技术文档编写（部署指南 .doc）",
    "业务文档编写（方案详情 .doc）",
    "标准版+高可用版合并文档编写",
    "3 版本输出：中国站中文 / 国际站中文 / 国际站英文",
    "方案页面文案优化与卖点提炼",
    "RFS URL 清单整理"
  ],
  "skills": [
    "sac-project-rules — 交付规范与文档标准",
    "sac-page-enhance — 文案增强与商品化"
  ],
  "inputs": [
    "架构师的设计文档",
    "开发 Agent 的部署模板",
    "参考文档模板：reference/docs/部署指南模板-华为云标准.md"
  ],
  "outputs": [
    "practices/{project}/{site}/docs/{Name}-Deployment-Guide.md          # 部署指南",
    "practices/{project}/{site}/docs/{Name}-Solution-Details.md          # 业务文档",
    "practices/{project}/intl/docs/zh-cn/{Name}-Deployment-Guide.md     # 国际站中文",
    "practices/{project}/intl/docs/zh-cn/{Name}-Solution-Details.md     # 国际站中文",
    "practices/{project}/intl/docs/en-us/{Name}-Deployment-Guide.md     # 国际站英文",
    "practices/{project}/intl/docs/en-us/{Name}-Solution-Details.md     # 国际站英文",
    "RFS URL 清单（url.txt）"
  ],
}

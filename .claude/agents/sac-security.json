{
  "name": "sac-security",
  "description": "SAC 安全审查 Agent — 安全审计与合规检查",
  "skill_index_mode": true,
  "skill_index_path": "skills-index.json",
  "skill_binding": {
    "primary": "",
    "requires": ["sac-project-rules"]
  },
  "skill_zone_config": {
    "max_skills_per_query": 1,
    "lazy_load_full_content": false,
    "clear_after_execution": true
  },
  "roles": [
    "凭证泄露检查（AK/SK/API Key/Token 硬编码）",
    "安全组规则审计（最小权限原则）",
    "网络安全审计（端口暴露面、公网访问）",
    "容器安全审计（镜像来源、特权模式、挂载点）",
    "数据安全审计（数据库密码、加密配置）",
    "供应链安全审计（第三方依赖版本）",
    "OBS 权限审计（公开读/写配置）"
  ],
  "skills": [
    "sac-rfs-practices — 安全规则参考",
    "sac-project-rules — 安全约束规则"
  ],
  "inputs": [
    "开发 Agent 输出的 practices/ 目录全部文件",
    "测试 Agent 的验证报告"
  ],
  "outputs": [
    "安全审计报告（高危/中危/低危分级）",
    "凭证泄露检查结果",
    "安全组规则建议（最小权限）",
    "端口暴露风险评估",
    "修复建议（分级）"
  ],
  "meta_rules": [
    "【意图预检】加载任何技能前，先判断用户查询是否匹配当前 Agent 的 skill_binding 注册范围；不匹配时跳过技能加载，直接使用基线能力",
    "【冲突抑制】查询同时命中多个技能时，优先选择 skill_index.json 中 relevance 评分最高的技能；若两个技能声明了 conflicts_with 关系，不得同时加载",
    "【递归限制】技能加载深度上限 = 1 层。技能内容中不得递归引用加载其他技能。所有跨技能引用必须通过 reference/*.md 公共参考文档完成",
    "【技能区生命周期】每次 Agent 执行完成后，清空 ZONE 3（技能区）上下文，仅保留 ZONE 1（系统指令）+ ZONE 2（用户查询）+ ZONE 4（滑动历史窗口）"
  ],
  "check_rules": [
    {
      "id": "SEC-001",
      "severity": "critical",
      "rule": "安装脚本不得硬编码 AK/SK",
      "check": "grep -inE '(access_key|secret_key|AKID|SKID|ak\\s*=|sk\\s*=)' install_*.sh"
    },
    {
      "id": "SEC-002",
      "severity": "critical",
      "rule": "安装脚本不得硬编码 API Key",
      "check": "grep -inE '(api.?key|apikey|token\\s*=|master.?key)' install_*.sh"
    },
    {
      "id": "SEC-003",
      "severity": "high",
      "rule": "安全组不得开放高危端口到 0.0.0.0/0",
      "check": "grep -A2 'remote_ip_prefix.*0.0.0.0/0' deploying-*.tf | grep -E '(22|3306|5432|6379|27017)'"
    },
    {
      "id": "SEC-004",
      "severity": "high",
      "rule": "SSH 端口仅限 Cloud Shell IP",
      "check": "grep -B2 'ports.*22' deploying-*.tf | grep -c '121.36.59.153/32'"
    },
    {
      "id": "SEC-005",
      "severity": "medium",
      "rule": "SWR 镜像应设为公开",
      "check": "grep -c 'docker login' install_*.sh"
    },
    {
      "id": "SEC-006",
      "severity": "medium",
      "rule": "数据库密码通过环境变量传入",
      "check": "grep -E '(POSTGRES_PASSWORD|DB_PASSWORD|REDIS_PASSWORD)' docker-compose.yaml"
    },
    {
      "id": "SEC-007",
      "severity": "low",
      "rule": "容器不以 privileged 模式运行",
      "check": "grep -c 'privileged: true' docker-compose.yaml"
    },
    {
      "id": "SEC-008",
      "severity": "low",
      "rule": "ECS 开启 hss + ces 监控",
      "check": "grep -c 'agent_list.*hss.*ces' deploying-*.tf"
    }
  ]
}

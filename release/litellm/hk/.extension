    "system_disk_size": { "group": "ecs_config", "order": 3 },
    "master_key": { "group": "litellm_config", "order": 1 },
    "db_password": { "group": "litellm_config", "order": 2 },
    "salt_key": { "group": "litellm_config", "order": 3 },
    "charging_mode": { "group": "charging_config", "order": 1 },
    "charging_unit": { "group": "charging_config", "order": 2 },
    "charging_period": { "group": "charging_config", "order": 3 }
  },
  "group_labels": {
    "network_config": { "en": "Network Configuration", "zh_cn": "网络配置" },
    "ecs_config": { "en": "ECS Configuration", "zh_cn": "弹性云服务器配置" },

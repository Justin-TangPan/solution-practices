{
  "variables": {
    "grouping": {
      "network_config": {
        "label": "Network Configuration",
        "description": "Configure VPC, subnets, EIP bandwidth, and NAT gateway"
      },
      "litellm_config": {
        "label": "LiteLLM Configuration",
        "description": "Configure LiteLLM version, master key, and salt key"
      },
      "cce_config": {
        "label": "CCE Cluster Configuration",
        "description": "Configure CCE cluster flavor, node pool, and password"
      },
      "database_config": {
        "label": "Database & Cache Configuration",
        "description": "Configure RDS PostgreSQL and DCS Redis"
      },
      "charging_config": {
        "label": "Billing Configuration",
        "description": "Configure billing mode (pay-per-use/subscription) and purchase period"
      }
    }
  },
  "i18n": {
    "en-us": {
      "variable": {
        "resource_name_prefix": { "description": "Resource name prefix. Naming rule: {prefix}-{resource_name}. Range: 4-24 characters, lowercase letters, digits, hyphens. Must start with lowercase letter. Default: ha-litellm" },
        "bandwidth_size": { "description": "Elastic IP bandwidth (Mbit/s), traffic-based billing. Range: 1-300. Default: 300" },
        "elb_certificate_id": { "description": "Existing ELB server certificate ID for the mandatory HTTPS/443 public listener." },
        "litellm_version": { "description": "Pinned LiteLLM Proxy image version. This HA template only accepts docker.litellm.ai/berriai/litellm:1.87.0" },
        "litellm_master_key": { "description": "CSPRNG-generated LiteLLM master key. Must start with sk-, total length 32-64, using letters, digits, underscores, or hyphens." },
        "litellm_salt_key": { "description": "CSPRNG-generated LiteLLM salt key for database encryption. 32-64 letters, digits, underscores, or hyphens. Cannot be changed once set." },
        "cce_cluster_flavor": { "description": "CCE Turbo cluster flavor. Default: cce.s2.small (small-scale multi-master, max 50 nodes). Options: cce.s2.small/medium/large/xlarge" },
        "cce_node_pool_password": { "description": "CCE cluster node password. 8-24 characters, must contain uppercase, lowercase, and digit or special character." },
        "cce_node_pool_flavor": { "description": "CCE node ECS instance flavor. Recommended: c7n.2xlarge.2 (4C8G per instance for LiteLLM production). Default: c7n.2xlarge.2" },
        "cce_node_pool_count": { "description": "Initial number of nodes in the CCE node pool. Range: 1-9. Default: 3" },
        "rds_flavor": { "description": "RDS for PostgreSQL primary/standby instance flavor. Default: rds.pg.x1.2xlarge.2.ha (8U16G dedicated)" },
        "pgsql_admin_password": { "description": "PostgreSQL administrator password. 8-24 characters, must contain uppercase, lowercase, and digit or special character." },
        "redis_capacity": { "description": "DCS Redis instance capacity in GB. Options: 1/2/4/8/16/32/64. Default: 8" },
        "redis_password": { "description": "Redis password. 8-24 characters, must contain uppercase, lowercase, and digit or special character." },
        "charging_mode": { "description": "Billing mode: postPaid (pay-per-use) or prePaid (subscription). Default: postPaid" },
        "charging_unit": { "description": "Subscription period unit: month or year. Only effective for prePaid mode. Default: month" },
        "charging_period": { "description": "Subscription period: 1-9 (months) or 1-3 (years). Only effective for prePaid mode. Default: 1" }
      }
    },
    "zh-cn": {
      "variable": {
        "resource_name_prefix": { "description": "资源名称前缀。命名规则：{前缀}-{资源英文名}。取值范围：4-24字符，支持小写字母、数字、中划线，须以小写字母开头。默认：ha-litellm" },
        "bandwidth_size": { "description": "弹性公网带宽大小（Mbit/s），按流量计费。取值范围：1-300。默认：300" },
        "elb_certificate_id": { "description": "现有 ELB 服务器证书 ID，用于强制启用公网 HTTPS/443 监听器。" },
        "litellm_version": { "description": "固定的 LiteLLM Proxy 镜像版本。本高可用模板仅接受 docker.litellm.ai/berriai/litellm:1.87.0" },
        "litellm_master_key": { "description": "使用密码学安全随机数生成的 LiteLLM 主密钥。须以 sk- 开头，总长32-64位，仅使用字母、数字、下划线或中划线。" },
        "litellm_salt_key": { "description": "使用密码学安全随机数生成的 LiteLLM 数据加密密钥。32-64位，仅使用字母、数字、下划线或中划线，一旦使用不可更改。" },
        "cce_cluster_flavor": { "description": "CCE Turbo 集群规格。默认：cce.s2.small（小规模多控制节点，最大50节点）。可选：cce.s2.small/medium/large/xlarge" },
        "cce_node_pool_password": { "description": "CCE 集群节点密码。8-24位，须包含大写字母、小写字母、数字或特殊字符。" },
        "cce_node_pool_flavor": { "description": "CCE 节点 ECS 实例规格。建议至少满足 LiteLLM 官方 4C8G/实例的生产建议。默认：c7n.2xlarge.2" },
        "cce_node_pool_count": { "description": "CCE 节点池初始节点数。取值范围：1-9。默认：3" },
        "rds_flavor": { "description": "RDS for PostgreSQL 主备版实例规格。默认：rds.pg.x1.2xlarge.2.ha（8U16G 独享型）" },
        "pgsql_admin_password": { "description": "PostgreSQL 管理员密码。8-24位，须包含大写字母、小写字母、数字或特殊字符。" },
        "redis_capacity": { "description": "DCS Redis 实例容量（GB）。可选：1/2/4/8/16/32/64。默认：8" },
        "redis_password": { "description": "Redis 密码。8-24位，须包含大写字母、小写字母、数字或特殊字符。" },
        "charging_mode": { "description": "计费模式：postPaid（按需）或 prePaid（包年包月）。默认：postPaid" },
        "charging_unit": { "description": "订购周期类型：month（月）或 year（年）。仅 prePaid 时生效。默认：month" },
        "charging_period": { "description": "订购周期：按月1-9，按年1-3。仅 prePaid 时生效。默认：1" }
      }
    }
  }
}

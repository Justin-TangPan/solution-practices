{
  "formal": {
    "practices": [
      "litellm",
      "supabase",
      "openjiuwen"
    ],
    "exclude": [
      "web",
      ".claude",
      "scripts/archive",
      "scripts/experimental"
    ]
  },
  "quality_gate": {
    "require_terraform_dir": true,
    "require_scripts_dir": false,
    "require_extension": false,
    "allow_inline_install_script": true,
    "practice_policies": {
      "openjiuwen/cn/cn-north-4/jiuwenswarm": {
        "single_candidate": true,
        "inline_user_data": true,
        "forbidden_variables": [
          "frontend_port",
          "web_access_cidr",
          "requirements_lock_url"
        ],
        "eip": {
          "default_bandwidth": 300,
          "charging_mode": "postPaid",
          "bandwidth_charge_mode": "traffic"
        },
        "official_default_interface": {
          "port": 5173,
          "remote_ip_prefix": "0.0.0.0/0",
          "do_not_override_runtime_port": true
        }
      }
    },
    "documentation": {
      "strict": false,
      "require_docx": false,
      "require_bilingual_intl": false,
      "block_on_pipeline_errors": true
    }
  },
  "document_pipeline": {
    "enabled": true,
    "offline": true,
    "output_root": "output/document-pipeline",
    "template_dir": "scripts/document_pipeline/templates",
    "config_dir": "scripts/document_pipeline/config",
    "translator_provider": "offline",
    "publish_requires_manual_review": true
  },
  "distribution": {
    "npm_package": "solution-practices",
    "node_minimum": "20",
    "manifest_schema_version": 1,
    "content_version": "2026.07",
    "managed_file_policies": {
      "AGENTS.md": "merge-block",
      ".codex/agents/sac-*": "managed",
      ".codex/workflows/*": "managed",
      ".codex/skills/sac-*": "managed",
      "skills/sac-*": "managed",
      "practices/*": "managed-unless-modified"
    }
  },
  "asset_status": {
    "practices": "formal",
    "skills": "formal",
    "scripts/tests": "formal",
    "package.json": "formal",
    "bin/sac.js": "formal",
    "src": "formal",
    "templates": "formal",
    "scripts/obs": "optional",
    ".codex/agents": "local",
    ".codex/workflows": "local",
    ".claude/agents": "local",
    ".claude/workflows": "local",
    "web": "experimental"
  }
}
